<mujoco model="go2 room scene">
  <include file="../src/unitree_mujoco/unitree_robots/go2/go2.xml"/>

  <statistic center="0 0 0.5" extent="3"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
        markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <!-- Rail track: rails mesh + gravel ground mesh -->
    <mesh name="rails"  file="model/meshId0.obj" scale="0.01 0.01 0.01"/>
    <mesh name="gravel" file="model/meshId1.obj" scale="0.01 0.01 0.01"/>
    <texture name="tex_rails"  type="2d" file="model/textures/solid_glass_albedo.png"/>
    <texture name="tex_gravel" type="2d" file="model/textures/wall_paint_albedo.png"/>
    <material name="mat_rails"  texture="tex_rails"/>
    <material name="mat_gravel" texture="tex_gravel"/>

  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <geom name="rails"  type="mesh" mesh="rails"  material="mat_rails"  pos="-0.8 1.5 0.09"/>
    <geom name="gravel" type="mesh" mesh="gravel" material="mat_gravel" pos="-0.4 1.5 0.06"/>
    <!-- External spectator camera: side-elevated view -->
    <camera name="right" pos="1 -2 1.0" xyaxes="1 0 0 0 0.447 0.894"/>
    <camera name="bird_eye" pos="0.8 1.5 5" xyaxes="1 0 0 0 1 0"/>
  </worldbody>
</mujoco>
